# Copy to .env and fill in. All values have safe defaults.
APP_ENV=development
LOG_LEVEL=info

# Leave blank to use the deterministic mock provider (great for demos).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7

# CORS allowlist (comma-separated). Use * only in dev.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# SQLite file location
DATABASE_URL=sqlite:///./devpost_companion.db